[[source]]
name = "pypi"
url = "https://pypi.org/simple"
verify_ssl = true

[dev-packages]
pytest = "*"
pytest-cov = "*"
mock = "*"
flake8 = "*"
flake8-docstrings = "*"
flake8-import-order = "*"
black = "==19.3b0"
sphinx = "*"
mypy = "*"
sphinx-rtd-theme = "*"
epicscorelibs = "*"
epicsdbbuilder = "*"

[packages]
# All other package requirements from setup.cfg
pyburt = {editable = true, path = "."}

[scripts]
tests = "python -m pytest --cov=burt tests/unit"
docs = "sphinx-build -E -b html docs build/html"
