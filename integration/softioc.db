# AI (double)
record(ai, "SR-CS-SOFT-01:AI")
{
    field (VAL, "0")
    field (PREC, "2")
    field (PINI, "YES")
    field (DISS, "3")
}
# AO (double)
record(ao, "SR-CS-SOFT-01:AO")
{
    field (VAL, "70.0")
    field (DRVL, "70.0")
    field (DRVH, "150.0")
    field (PREC, "1")
    field (PINI, "YES")
    field (DISS, "3")
}
# Double waveform
record (waveform, "SR-CS-SOFT-01:DOUBLE_ARR")
{
    field (NELM, "8")
    field (FTVL, "DOUBLE")
    field (PINI, "YES")
    field (DISS, "3")
}
# Float waveform (no simple float record)
record (waveform, "SR-CS-SOFT-01:FLOAT_ARR")
{
    field (NELM, "8")
    field (FTVL, "FLOAT")
    field (PINI, "YES")
    field (DISS, "3")
}
# Empty string
record(stringin, "SR-CS-SOFT-01:EMPTYSTRING") {
}
# String in
record(stringin, "SR-CS-SOFT-01:STRINGIN") {
  field(DESC, "Gen Time Current Provider")
  field(DTYP, "General Time")
  field(INP,  "@BESTTCP")
  field(SCAN, "1 second")
}
# String out
record(stringout, "SR-CS-SOFT-01:STRINGOUT") {
  field(DESC, "Gen Time Current Provider")
  field(SCAN, "1 second")
}
# String waveform
record (waveform, "SR-CS-SOFT-01:STRING_ARR")
{
    field (NELM, "3")
    field (FTVL, "STRING")
    field (PINI, "YES")
    field (DISS, "3")
}
# Char waveform (no simple char record)
record (waveform, "SR-CS-SOFT-01:CHAR_ARR")
{
    field (NELM, "20")
    field (FTVL, "CHAR")
    field (PINI, "YES")
    field (DISS, "3")
}
# Short waveform (no simple short record)
record (waveform, "SR-CS-SOFT-01:SHORT_ARR")
{
    field (NELM, "8")
    field (FTVL, "SHORT")
    field (PINI, "YES")
    field (DISS, "3")
}
# Long in
record(longin, "SR-CS-SOFT-01:LONGIN") {
  field(DESC, "Gen Time Error Count")
  field(DTYP, "General Time")
  field(INP,  "@GETERRCNT")
  field(SCAN, "1 second")
  field(HIHI, "1")
  field(HHSV, "MAJOR")
}
# Long out
record(longout, "SR-CS-SOFT-01:LONGOUT") {
  field(DESC, "Gen Time Error Count")
  field(SCAN, "1 second")
  field(HIHI, "1")
  field(HHSV, "MAJOR")
}
# Long waveform
record (waveform, "SR-CS-SOFT-01:LONG_ARR")
{
    field (NELM, "8")
    field (FTVL, "LONG")
    field (PINI, "YES")
    field (DISS, "3")
}
# MBBI
record (mbbi, "SR-CS-SOFT-01:MBBI")
{
    field (VAL, "0")
    field (ZRST, "OK")
    field (ONST, "Fault")
    field (TWST, "Warning")
    field (PINI, "YES")
    field (DISS, "3")
}
# MBBO
record(mbbo, "SR-CS-SOFT-01:MBBO")
{
  field(DESC, "SR-CS-IOC-01 Acc Mode")
  field(PINI, "YES")
  field(ZRST, "Running")
  field(ZRSV, "NO_ALARM")
  field(ONST, "Maintenance")
  field(ONSV, "MINOR")
  field(TWST, "Test")
  field(TWSV, "MINOR")
  field(THST, "OFFLINE")
  field(THSV, "MAJOR")
  info(autosaveFields, "VAL")
}
# BI
record(bi, "SR-CS-SOFT-01:BI")
{
    field (VAL, "0")
    field (ZNAM, "OK")
    field (ONAM, "Fault")
    field (PINI, "YES")
    field (DISS, "3")
}
# BO
record(bo, "SR-CS-SOFT-01:BO") {
  field(DESC, "Gen Time Error Reset")
  field(DTYP, "General Time")
  field(OUT,  "@RSTERRCNT")
  field(ZNAM, "Reset")
  field(ONAM, "Reset")
}
